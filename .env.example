# ── Application ───────────────────────────────────────────────────────────────
APP_ENV=development
SECRET_KEY=change-me-to-a-long-random-secret-key-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── PostgreSQL ─────────────────────────────────────────────────────────────────
POSTGRES_USER=enterprise
POSTGRES_PASSWORD=enterprise_secret
POSTGRES_DB=enterprise_brain
DATABASE_URL=postgresql+asyncpg://enterprise:enterprise_secret@postgres:5432/enterprise_brain
SYNC_DATABASE_URL=postgresql://enterprise:enterprise_secret@postgres:5432/enterprise_brain

# ── Redis ──────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=redis_secret
REDIS_URL=redis://:redis_secret@redis:6379/0

# ── Neo4j ──────────────────────────────────────────────────────────────────────
NEO4J_USER=neo4j
NEO4J_PASSWORD=neo4j_secret
NEO4J_URI=bolt://neo4j:7687

# ── Qdrant ─────────────────────────────────────────────────────────────────────
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_COLLECTION=enterprise_brain

# ── MinIO ──────────────────────────────────────────────────────────────────────
MINIO_ROOT_USER=minio_admin
MINIO_ROOT_PASSWORD=minio_secret
MINIO_ENDPOINT=minio:9000
MINIO_BUCKET=enterprise-brain
MINIO_SECURE=false

# ── LLM ───────────────────────────────────────────────────────────────────────
# Get your key from https://console.anthropic.com
ANTHROPIC_API_KEY=your-anthropic-api-key-here
LLM_MODEL=claude-sonnet-4-6
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIM=384

# ── Frontend ───────────────────────────────────────────────────────────────────
# Use http://localhost:8000 for direct backend access (port 8000 is exposed)
# Use http://localhost to route all traffic through nginx on port 80
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_NAME=Enterprise Brain

# ── Celery ─────────────────────────────────────────────────────────────────────
CELERY_BROKER_URL=redis://:redis_secret@redis:6379/1
CELERY_RESULT_BACKEND=redis://:redis_secret@redis:6379/2
